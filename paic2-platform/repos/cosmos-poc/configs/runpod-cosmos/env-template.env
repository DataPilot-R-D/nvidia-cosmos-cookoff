COSMOS_API_BASE=http://<pod_host>:8899/v1
COSMOS_AWS_API_BASE=http://<aws_host>:8899/v1
COSMOS_API_KEY=EMPTY
COSMOS_MODEL=nvidia/Cosmos-Reason2-8B
COSMOS_MAX_MODEL_LEN=32768
COSMOS_MAX_TOKENS=1024
COSMOS_PROVIDER=runpod

RUNPOD_API_KEY=<runpod_api_key>
RUNPOD_COSMOS_LOG_DIR=logs/runpod-cosmos
RUNPOD_COSMOS_DEFAULT_WARM_MINUTES=60
RUNPOD_COSMOS_API_HOST=
RUNPOD_COSMOS_API_PORT=
RUNPOD_COSMOS_LOCAL_TUNNEL_PORT=18899
RUNPOD_COSMOS_PROMPT_TIMEOUT_SECONDS=120
RUNPOD_COSMOS_BOOTSTRAP_TIMEOUT_SECONDS=1800
RUNPOD_SSH_USER=root
