{
  "name": "websocket-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:node": "tsx watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "build:tsc": "tsc",
    "start": "bun dist/index.js",
    "start:node": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:jest": "jest",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@socket.io/bun-engine": "^0.1.0",
    "@types/sharp": "^0.32.0",
    "@workspace/shared-types": "workspace:*",
    "@workspace/wasm-processing": "workspace:*",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-msgpack-parser": "^3.0.2",
    "systeminformation": "^5.30.6",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
