# Server Configuration
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# CORS Settings
WS_CORS_ORIGIN=http://localhost:3000

# ROS Bridge Connection (optional - can also be configured via UI)
# If not set, ROSBridge connection will be disabled until configured via dashboard
ROS_BRIDGE_URL=ws://localhost:9090

# go2rtc WebRTC Server (API port, not the WebRTC UDP port)
# go2rtc handles WebRTC signaling and media relay for camera streams
GO2RTC_URL=http://localhost:1984
