# PAIC2 platform environment template
# Do not place secret values in this file.

OPENAI_BASE_URL=
OPENAI_MODEL=

# Resolve secret values from AWS SSM/Secrets Manager at runtime.
OPENAI_API_KEY_SSM_PARAM=/sras/prod/openai/api_key
RUNPOD_API_KEY_SSM_PARAM=/sras/prod/runpod/api_key
MOONDREAM_API_KEY_SSM_PARAM=/sras/prod/moondream/api_key
ALIBABA_API_KEY_SSM_PARAM=/sras/prod/alibaba/api_key

ROS_DOMAIN_ID=0
SRAS_ENVIRONMENT=prod
