{
  "name": "security-robot-command-center",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Security Robot Command Center - Dashboard, WebSocket Server, ROS 2 Bridge",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "dev:web": "pnpm --filter web-client dev",
    "dev:ws": "pnpm --filter websocket-server dev",
    "build": "pnpm --recursive --filter './apps/*' build",
    "build:web": "pnpm --filter web-client build",
    "build:ws": "pnpm --filter websocket-server build",
    "test": "pnpm --recursive test",
    "test:unit": "pnpm --recursive test:unit",
    "test:e2e": "pnpm --filter web-client test:e2e",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "type-check": "pnpm --recursive type-check",
    "clean": "pnpm --recursive clean && rm -rf node_modules",
    "docker:up": "docker-compose -f docker/docker-compose.yml up",
    "docker:dev": "docker-compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.12.1"
}
